{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "KoharuZen",
  "identifier": "KoharuZen",
  "build": {
    "beforeDevCommand": "bun --cwd ui dev",
    "beforeBuildCommand": "bun --cwd ui build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../ui/out"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "create": false,
        "url": "about:blank",
        "width": 1024,
        "height": 768,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "title": "KoharuZen",
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "deb", "rpm", "appimage", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlFMkM0MTc5Q0NGOUNGODEKUldTQnovbk1lVUVzbm1aeU14dmZLTjV1cHgyb0QwMWJCQ05WcnBETVFKUzF1Rzc1VHJnbDcxMEQK",
      "endpoints": [
        "https://github.com/nawka12/KoharuZen/releases/latest/download/latest.json"
      ]
    }
  }
}
